
import React, { useState } from 'react';
// Fix: Ignore potential type definition issues with react-router-dom in this environment
// @ts-ignore
import { useParams, useNavigate } from 'react-router-dom';
import { LineChart, Line, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer } from 'recharts';
import { MOCK_CREATORS } from './BrowseCreators';
import { IconTikTok, IconInstagram, IconYouTube, IconX, IconMessaging } from '../components/Icons';
import { GoogleGenAI } from "@google/genai";

const TREND_DATA = [
  { day: 'Day 1', views: 420000 },
  { day: 'Day 5', views: 480000 },
  { day: 'Day 10', views: 450000 },
  { day: 'Day 15', views: 590000 },
  { day: 'Day 20', views: 720000 },
  { day: 'Day 25', views: 680000 },
  { day: 'Day 30', views: 840000 },
];

const PerformanceCard = ({ 
  label, 
  value, 
  description, 
  icon, 
  colorClass, 
  trend, 
  platforms 
}: { 
  label: string, 
  value: string, 
  description: string, 
  icon: string, 
  colorClass: string, 
  trend?: string,
  platforms?: React.ReactNode
}) => (
  <div className="bg-[#11141A] border border-white/5 p-8 md:p-10 rounded-[48px] relative overflow-hidden group hover:border-teal-500/30 transition-all duration-500 shadow-2xl flex flex-col justify-between min-h-[260px]">
    <div className={`absolute -top-10 -right-10 w-48 h-48 ${colorClass} opacity-[0.05] blur-3xl group-hover:opacity-[0.12] transition-opacity duration-700`}></div>
    
    <div className="relative z-10 flex justify-between items-start">
      <div className="w-16 h-16 bg-white/5 rounded-[24px] flex items-center justify-center text-4xl border border-white/5 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-500 shadow-inner">
        {icon}
      </div>
      <div className="flex flex-col items-end gap-2">
        {trend && (
          <span className="text-[10px] font-black text-teal-400 bg-teal-400/10 px-3 py-1.5 rounded-xl uppercase tracking-widest border border-teal-400/20">
            {trend}
          </span>
        )}
        <div className="flex gap-2 opacity-40 group-hover:opacity-100 transition-opacity">
          {platforms}
        </div>
      </div>
    </div>

    <div className="relative z-10 space-y-3 mt-8">
      <p className="text-[10px] font-black text-gray-500 uppercase tracking-[0.4em] ml-1">{label}</p>
      <div className="flex items-end gap-3">
        <h3 className="text-5xl md:text-6xl font-black text-white tracking-tighter leading-none">{value}</h3>
      </div>
      <p className="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1 leading-relaxed">{description}</p>
    </div>
    
    <div className="absolute bottom-0 left-0 h-1.5 w-0 bg-gradient-to-r from-transparent via-teal-500 to-transparent group-hover:w-full transition-all duration-1000 opacity-60"></div>
  </div>
);

const CreatorDetail: React.FC = () => {
  const { id } = useParams();
  const navigate = useNavigate();
  const creator = MOCK_CREATORS.find(c => c.id === id);

  const [isContactModalOpen, setIsContactModalOpen] = useState(false);
  const [message, setMessage] = useState('');
  const [isSending, setIsSending] = useState(false);
  const [sentSuccess, setSentSuccess] = useState(false);
  const [isFollowing, setIsFollowing] = useState(false);
  const [selectedGalleryImage, setSelectedGalleryImage] = useState<string | null>(null);

  // Gemini State
  const [aiInsights, setAiInsights] = useState<string | null>(null);
  const [isAiAnalyzing, setIsAiAnalyzing] = useState(false);
  const [isPolishing, setIsPolishing] = useState(false);

  if (!creator) {
    return (
      <div className="p-20 text-center text-white font-display text-2xl">
        Creator Protocol Endpoint Not Found
      </div>
    );
  }

  const runAiAudit = async () => {
    setIsAiAnalyzing(true);
    try {
      const ai = new GoogleGenAI({ apiKey: process.env.API_KEY });
      const response = await ai.models.generateContent({
        model: 'gemini-3-flash-preview',
        contents: `Analyze this creator for a potential brand campaign on a platform called Kreaterly (Africa's Shopify for Creators). 
        Name: ${creator.name}
        Bio: ${creator.bio}
        Interests: ${creator.interests.join(', ')}
        Stats: TikTok (${creator.stats.tiktok.followers} followers), Instagram (${creator.stats.instagram.followers} followers).
        Provide a concise 3-bullet point summary of their unique value and specific brand categories they would excel in. Keep it professional and high-tech.`,
      });
      setAiInsights(response.text);
    } catch (err) {
      setAiInsights("Failed to sync with Gemini Nucleus. Audit offline.");
    } finally {
      setIsAiAnalyzing(false);
    }
  };

  const handleAiPolish = async () => {
    if (!message.trim()) return;
    setIsPolishing(true);
    try {
      const ai = new GoogleGenAI({ apiKey: process.env.API_KEY });
      const response = await ai.models.generateContent({
        model: 'gemini-3-flash-preview',
        contents: `Rewrite this message to be more professional, persuasive, and customized for the creator ${creator.name}. 
        Niche: ${creator.interests[0]}. 
        The platform is Kreaterly, and the brand is reaching out for a gig. 
        Original draft: "${message}" 
        Return only the polished text, no commentary.`,
      });
      setMessage(response.text || message);
    } catch (err) {
      console.error("Polish failed", err);
    } finally {
      setIsPolishing(false);
    }
  };

  const handleSendMessage = (e: React.FormEvent) => {
    e.preventDefault();
    if (!message.trim()) return;
    setIsSending(true);
    setTimeout(() => {
      setIsSending(false);
      setSentSuccess(true);
      setTimeout(() => {
        setIsContactModalOpen(false);
        setSentSuccess(false);
        setMessage('');
      }, 2000);
    }, 1500);
  };

  const parseMetric = (val: string) => {
    const num = parseFloat(val.replace(/[^\d.]/g, ''));
    if (val.toLowerCase().includes('k')) return num * 1000;
    if (val.toLowerCase().includes('m')) return num * 1000000;
    return num;
  };

  const formatMetric = (num: number) => {
    if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M';
    if (num >= 1000) return (num / 1000).toFixed(1) + 'k';
    return num.toString();
  };

  const totalFollowers = parseMetric(creator.stats.tiktok.followers) + parseMetric(creator.stats.instagram.followers);
  const avgEngagement = (parseFloat(creator.stats.tiktok.engagement) + parseFloat(creator.stats.instagram.engagement)) / 2;
  const totalViews = parseMetric(creator.stats.tiktok.avgViews) + parseMetric(creator.stats.instagram.avgViews);

  const handleImageError = (e: React.SyntheticEvent<HTMLImageElement, Event>) => {
    const target = e.currentTarget;
    const fallbackId = '1529139572744-b1540a799c42';
    target.src = `https://images.unsplash.com/photo-${fallbackId}?auto=format&fit=crop&w=800&q=80`;
    target.onerror = null;
  };

  return (
    <div className="space-y-12 animate-in fade-in slide-in-from-bottom-6 duration-700 pb-20">
      {/* Contact Modal */}
      {isContactModalOpen && (
        <div className="fixed inset-0 z-[500] flex items-center justify-center p-4">
          <div 
            className="absolute inset-0 bg-[#0A0B0E]/90 backdrop-blur-md" 
            onClick={() => !isSending && setIsContactModalOpen(false)} 
          />
          <div className="bg-[#11141A] border border-white/10 w-full max-w-lg rounded-[48px] p-8 md:p-12 relative z-10 shadow-[0_50px_100px_rgba(0,0,0,0.8)] animate-in zoom-in-95 duration-300">
            <button 
              disabled={isSending}
              onClick={() => setIsContactModalOpen(false)}
              className="absolute top-8 right-8 text-gray-500 hover:text-white transition-colors"
            >
              <IconX />
            </button>

            {sentSuccess ? (
              <div className="py-12 text-center space-y-6 animate-in fade-in">
                <div className="w-20 h-20 bg-teal-500/20 border border-teal-500/40 rounded-full flex items-center justify-center mx-auto text-3xl text-teal-400">
                  ✓
                </div>
                <div className="space-y-2">
                  <h3 className="text-3xl font-black text-white uppercase font-display tracking-tight">Transmission Sent</h3>
                  <p className="text-gray-500 text-sm font-bold uppercase tracking-widest leading-relaxed">
                    Message routed to {creator.name.split(' ')[0]}'s hub.
                  </p>
                </div>
              </div>
            ) : (
              <form onSubmit={handleSendMessage} className="space-y-10">
                <div className="flex items-center gap-6">
                  <img src={creator.avatar} onError={handleImageError} className="w-16 h-16 rounded-2xl object-cover" alt="" />
                  <div>
                    <h3 className="text-2xl font-black text-white tracking-tight uppercase font-display leading-none">Contact {creator.name}</h3>
                    <p className="text-[10px] font-black text-teal-500 uppercase tracking-widest mt-1">Direct Protocol Transmission</p>
                  </div>
                </div>

                <div className="space-y-2">
                  <div className="flex justify-between items-end px-1">
                    <label className="text-[10px] font-black text-gray-500 uppercase tracking-widest">Your Message</label>
                    <button 
                      type="button"
                      disabled={isPolishing || !message.trim()}
                      onClick={handleAiPolish}
                      className="text-[9px] font-black text-purple-400 hover:text-purple-300 uppercase tracking-widest flex items-center gap-1.5 transition-colors disabled:opacity-30"
                    >
                      <span className={isPolishing ? 'animate-spin' : ''}>✨</span>
                      {isPolishing ? 'Polishing...' : 'AI Polish'}
                    </button>
                  </div>
                  <textarea 
                    autoFocus
                    required
                    maxLength={500}
                    value={message}
                    onChange={e => setMessage(e.target.value)}
                    disabled={isSending || isPolishing}
                    placeholder={`Hello ${creator.name.split(' ')[0]}, we're interested in partnering for a new campaign...`}
                    className="w-full bg-black/40 border border-white/5 rounded-3xl py-6 px-8 text-white font-medium focus:border-teal-500/50 outline-none transition-all placeholder:text-gray-800 resize-none h-40"
                  />
                  <div className="text-right px-1">
                    <span className="text-[8px] font-black text-gray-700 uppercase tracking-widest">{message.length}/500</span>
                  </div>
                </div>

                <button 
                  type="submit"
                  disabled={isSending || isPolishing || !message.trim()}
                  className="w-full bg-teal-500 text-black font-black py-6 rounded-[28px] text-lg uppercase tracking-tighter shadow-2xl shadow-teal-500/20 hover:brightness-110 active:scale-95 transition-all disabled:opacity-20"
                >
                  {isSending ? 'Transmitting...' : 'Send Message'}
                </button>
                <p className="text-center text-[8px] text-gray-700 font-black uppercase tracking-[0.4em]">
                  Encrypted Kampala Node Protocol
                </p>
              </form>
            )}
          </div>
        </div>
      )}

      {/* Gallery Modal */}
      {selectedGalleryImage && (
        <div className="fixed inset-0 z-[700] flex items-center justify-center p-4">
          <div className="absolute inset-0 bg-[#0A0B0E]/95 backdrop-blur-3xl" onClick={() => setSelectedGalleryImage(null)} />
          <div className="relative max-w-4xl w-full max-h-[90vh] flex flex-col items-center animate-in zoom-in-95 duration-300">
            <button 
              onClick={() => setSelectedGalleryImage(null)}
              className="absolute -top-16 right-0 text-white/40 hover:text-white transition-colors p-4"
            >
              <IconX />
            </button>
            <img src={selectedGalleryImage} className="max-w-full max-h-full object-contain rounded-3xl shadow-4xl shadow-black/80" alt="Full view" />
          </div>
        </div>
      )}

      {/* Navigation & Actions */}
      <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-6">
        <button 
          onClick={() => navigate(-1)} 
          className="text-[10px] font-black text-gray-500 hover:text-white uppercase tracking-[0.4em] transition-colors"
        >
          ← Back to Discovery
        </button>
        <div className="flex flex-wrap gap-4">
          <button className="bg-white/5 border border-white/10 text-white font-black px-6 py-3 rounded-xl text-[10px] uppercase tracking-widest hover:bg-white/10 transition-all">
            Shortlist
          </button>
          <button 
            onClick={() => setIsContactModalOpen(true)}
            className="flex items-center gap-2 bg-white/5 border border-white/10 text-white font-black px-6 py-3 rounded-xl text-[10px] uppercase tracking-widest hover:bg-teal-500/10 hover:text-teal-400 hover:border-teal-500/30 transition-all"
          >
            <IconMessaging />
            <span>Contact Creator</span>
          </button>
          <button className="bg-teal-500 text-black font-black px-10 py-3 rounded-xl text-[10px] uppercase tracking-widest shadow-xl shadow-teal-500/20 active:scale-95 transition-all">
            Invite to Gig
          </button>
        </div>
      </div>

      {/* Hero Profile Section */}
      <section className="relative group">
        <div className="absolute inset-0 bg-gradient-to-br from-teal-500/5 to-purple-500/5 rounded-[64px] blur-3xl opacity-50"></div>
        <div className="bg-[#11141A] border border-white/5 rounded-[64px] p-8 md:p-12 relative z-10 overflow-hidden">
          <div className="flex flex-col md:flex-row gap-10 items-center md:items-start text-center md:text-left">
            {/* Avatar Cluster */}
            <div className="relative flex-shrink-0">
              <div className="w-40 h-40 md:w-56 md:h-56 rounded-[56px] overflow-hidden border-4 border-teal-500/20 shadow-3xl relative bg-black/20">
                <img 
                  src={creator.avatar} 
                  onError={handleImageError}
                  className="w-full h-full object-cover" 
                  alt={creator.name} 
                />
                <div className="absolute inset-0 bg-black/20" />
              </div>
              <div className="absolute -bottom-4 -right-4 bg-[#0A0B0E] p-3 rounded-3xl border border-white/10 shadow-2xl">
                <span className="text-2xl">{creator.country.split(' ')[0]}</span>
              </div>
            </div>

            {/* Profile Info */}
            <div className="space-y-8 flex-1">
              <div className="space-y-6">
                <div className="flex flex-col md:flex-row md:items-end justify-between gap-6">
                  <div>
                    <p className="text-teal-500 text-[10px] font-black uppercase tracking-[0.4em]">Verified Creator Node</p>
                    <h1 className="text-5xl md:text-7xl font-black text-white tracking-tighter uppercase font-display leading-none">
                      {creator.name}
                    </h1>
                  </div>
                  <button 
                    onClick={runAiAudit}
                    disabled={isAiAnalyzing}
                    className="group/ai relative px-6 py-3 rounded-2xl bg-gradient-to-r from-purple-600/20 to-teal-500/20 border border-white/5 hover:border-purple-500/40 transition-all flex items-center gap-3 overflow-hidden disabled:opacity-50"
                  >
                    <div className="absolute inset-0 bg-gradient-to-r from-purple-500/10 to-teal-400/10 opacity-0 group-hover/ai:opacity-100 transition-opacity"></div>
                    <span className={`text-lg ${isAiAnalyzing ? 'animate-spin' : 'group-hover/ai:rotate-12 transition-transform'}`}>✨</span>
                    <span className="text-[10px] font-black text-white uppercase tracking-widest relative z-10">
                      {isAiAnalyzing ? 'Auditing Core...' : 'Gemini AI Audit'}
                    </span>
                  </button>
                </div>

                {/* AI Insights Card */}
                {aiInsights && (
                  <div className="bg-purple-500/5 border border-purple-500/20 rounded-[32px] p-8 animate-in slide-in-from-top-4 duration-500 relative overflow-hidden group/audit">
                    <div className="absolute top-0 right-0 p-4 opacity-20 text-3xl">✨</div>
                    <h4 className="text-[10px] font-black text-purple-400 uppercase tracking-[0.4em] mb-4">Gemini Intelligence Summary</h4>
                    <div className="text-gray-300 text-sm leading-relaxed space-y-4 whitespace-pre-wrap font-medium">
                      {aiInsights}
                    </div>
                  </div>
                )}

                <div className="space-y-8">
                  <p className="text-gray-400 font-medium text-lg leading-relaxed max-w-2xl">
                    {creator.bio}
                  </p>
                  <div className="flex justify-center md:justify-start">
                    <button 
                      onClick={() => setIsContactModalOpen(true)}
                      className="inline-flex items-center gap-3 bg-teal-500 text-black font-black px-12 py-5 rounded-[24px] text-[11px] uppercase tracking-[0.2em] shadow-2xl shadow-teal-500/30 active:scale-95 transition-all hover:brightness-110 group/btn"
                    >
                      <span className="group-hover/btn:rotate-12 transition-transform duration-300">
                        <IconMessaging />
                      </span>
                      <span>Contact Creator</span>
                    </button>
                  </div>
                </div>
              </div>

              {/* Social Link Chips */}
              <div className="space-y-4">
                <div className="flex flex-wrap justify-center md:justify-start gap-3 pt-2">
                  <div className="flex items-center gap-2 bg-black/40 border border-white/5 px-4 py-2.5 rounded-2xl hover:border-teal-500/30 transition-all cursor-pointer">
                    <span className="text-teal-400 scale-90"><IconTikTok /></span>
                    <span className="text-xs font-black text-white">{creator.stats.tiktok.handle}</span>
                  </div>
                  <div className="flex items-center gap-2 bg-black/40 border border-white/5 px-4 py-2.5 rounded-2xl hover:border-teal-500/30 transition-all cursor-pointer">
                    <span className="text-teal-400 scale-90"><IconInstagram /></span>
                    <span className="text-xs font-black text-white">{creator.stats.instagram.handle}</span>
                  </div>
                  <div className="flex items-center gap-2 bg-black/40 border border-white/5 px-4 py-2.5 rounded-2xl hover:border-teal-500/30 transition-all cursor-pointer">
                    <span className="text-gray-600 scale-90"><IconYouTube /></span>
                    <span className="text-xs font-black text-gray-600 uppercase tracking-widest">Connect YouTube</span>
                  </div>
                </div>

                {/* Follow Creator Button */}
                <div className="flex justify-center md:justify-start">
                  <button 
                    onClick={() => setIsFollowing(!isFollowing)}
                    className={`flex items-center gap-2 px-8 py-3 rounded-2xl text-[10px] font-black uppercase tracking-[0.1em] transition-all border ${
                      isFollowing 
                      ? 'bg-teal-500/10 border-teal-500/40 text-teal-400 shadow-[0_0_20px_rgba(20,184,166,0.1)]' 
                      : 'bg-white/5 border-white/10 text-white hover:bg-white/10 hover:border-white/20'
                    }`}
                  >
                    <span>{isFollowing ? '✓ Following Node' : '+ Follow Creator'}</span>
                  </button>
                </div>
              </div>

              {/* Interests */}
              <div className="flex flex-wrap justify-center md:justify-start gap-2">
                {creator.interests.map((int, i) => (
                  <span key={i} className="px-3 py-1.5 bg-white/5 border border-white/5 rounded-xl text-[10px] font-black text-gray-400 uppercase tracking-widest">
                    {int}
                  </span>
                ))}
              </div>
            </div>

            {/* Global Reach Stat (Desktop) */}
            <div className="hidden lg:block w-px h-56 bg-white/5 mx-4" />
            <div className="hidden lg:flex flex-col justify-center space-y-8 text-right">
               <div>
                 <p className="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-1">Global Reach</p>
                 <p className="text-5xl font-black text-white tracking-tighter">1.2M+</p>
               </div>
               <div>
                 <p className="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-1">Impact Score</p>
                 <p className="text-3xl font-black text-teal-400 tracking-tighter">9.8/10</p>
               </div>
            </div>
          </div>
        </div>
      </section>

      {/* KEY PERFORMANCE INDICATORS SECTION */}
      <section className="space-y-12">
        <div className="px-2 flex justify-between items-end">
          <div className="space-y-1">
            <h2 className="text-[10px] font-black text-teal-500 uppercase tracking-[0.6em] mb-3">Performance Analytics Protocol</h2>
            <p className="text-4xl md:text-5xl font-black text-white tracking-tighter uppercase font-display leading-none">Global Growth Matrix</p>
          </div>
          <div className="hidden sm:flex items-center gap-3 text-[10px] font-black text-gray-600 uppercase tracking-widest border border-white/10 px-6 py-3 rounded-2xl">
            Live Node Status: <span className="text-teal-500 ml-1 animate-pulse">● Active</span>
          </div>
        </div>
        
        <div className="grid grid-cols-1 md:grid-cols-3 gap-8">
          <PerformanceCard 
            label="Total Audience" 
            value={formatMetric(totalFollowers)} 
            description="Aggregate followers across verified social nodes" 
            icon="👥" 
            colorClass="bg-teal-500"
            trend="+14.2% MoM"
            platforms={
              <>
                <IconTikTok />
                <IconInstagram />
              </>
            }
          />
          <PerformanceCard 
            label="Avg. Engagement" 
            value={avgEngagement.toFixed(1) + '%'} 
            description="Platform interaction intensity & quality score" 
            icon="⚡" 
            colorClass="bg-purple-500"
            trend="Tier: Elite"
            platforms={
              <>
                <IconTikTok />
                <IconInstagram />
              </>
            }
          />
          <PerformanceCard 
            label="Video Reach" 
            value={formatMetric(totalViews)} 
            description="Monthly video views accumulated from verified assets" 
            icon="👁️" 
            colorClass="bg-orange-500"
            trend="High Velocity"
            platforms={
              <>
                <IconTikTok />
                <IconInstagram />
              </>
            }
          />
        </div>

        {/* 30-Day Views Trend Chart */}
        <div className="bg-[#11141A] border border-white/5 rounded-[56px] p-8 md:p-14 shadow-2xl relative overflow-hidden group">
          <div className="absolute inset-0 bg-gradient-to-br from-teal-500/5 via-transparent to-transparent opacity-30"></div>
          <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-8 mb-16 relative z-10">
            <div className="space-y-3">
              <h3 className="text-3xl md:text-4xl font-black text-white tracking-tighter uppercase font-display leading-none">Reach Velocity Index</h3>
              <p className="text-[11px] font-black text-teal-500 uppercase tracking-[0.3em]">Monthly Aggregate Analytics • Kampala Cluster v3.5</p>
            </div>
            <div className="flex bg-white/5 p-1.5 rounded-2xl border border-white/10 shadow-inner">
              <span className="px-6 py-3 text-[10px] font-black text-teal-400 bg-teal-400/10 rounded-xl border border-teal-400/20 uppercase tracking-[0.2em]">Verified Reach Node</span>
            </div>
          </div>
          
          <div className="h-[320px] w-full min-h-0 min-w-0 relative z-10">
            <ResponsiveContainer width="100%" height="100%">
              <LineChart data={TREND_DATA}>
                <defs>
                  <linearGradient id="viewsGradient" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%" stopColor="#14B8A6" />
                    <stop offset="100%" stopColor="#F97316" />
                  </linearGradient>
                </defs>
                <CartesianGrid strokeDasharray="4 4" stroke="#1f2937" vertical={false} strokeOpacity={0.15} />
                <XAxis 
                  dataKey="day" 
                  stroke="#4b5563" 
                  fontSize={10} 
                  tickLine={false} 
                  axisLine={false} 
                  tick={{ fontWeight: 900 }}
                  dy={15}
                />
                <YAxis 
                  stroke="#4b5563" 
                  fontSize={10} 
                  tickLine={false} 
                  axisLine={false} 
                  tickFormatter={(val) => `${val / 1000}k`}
                  tick={{ fontWeight: 900 }}
                  dx={-10}
                />
                <Tooltip 
                  contentStyle={{ backgroundColor: '#11141A', border: '1px solid rgba(20, 184, 166, 0.2)', borderRadius: '24px', boxShadow: '0 25px 50px -12px rgba(0,0,0,0.8)', padding: '20px' }}
                  itemStyle={{ color: '#14B8A6', fontWeight: 900, fontSize: '12px' }}
                  labelStyle={{ fontWeight: 900, fontSize: '10px', color: '#6b7280', marginBottom: '8px', textTransform: 'uppercase', letterSpacing: '0.2em' }}
                />
                <Line 
                  type="monotone" 
                  dataKey="views" 
                  stroke="url(#viewsGradient)" 
                  strokeWidth={6} 
                  dot={{ r: 6, fill: '#14B8A6', strokeWidth: 4, stroke: '#11141A' }}
                  activeDot={{ r: 10, fill: '#F97316', strokeWidth: 0 }}
                  animationDuration={3000}
                />
              </LineChart>
            </ResponsiveContainer>
          </div>
        </div>
      </section>

      {/* Detailed Stats Matrix */}
      <section className="grid grid-cols-1 md:grid-cols-2 gap-8">
        {/* TikTok Metrics */}
        <div className="bg-[#11141A] border border-white/5 rounded-[48px] p-8 md:p-10 space-y-10 relative overflow-hidden group">
           <div className="absolute top-[-20%] right-[-10%] w-48 h-48 bg-teal-500/5 rounded-full blur-3xl group-hover:bg-teal-500/10 transition-all"></div>
           <div className="flex items-center gap-4">
              <div className="w-14 h-14 bg-black rounded-2xl flex items-center justify-center text-teal-400 border border-white/10 shadow-2xl">
                <IconTikTok />
              </div>
              <div>
                <h3 className="text-2xl font-black text-white tracking-tight uppercase font-display leading-none">TikTok Performance</h3>
                <p className="text-[10px] font-black text-teal-500 uppercase tracking-widest mt-1">Real-time Node Status</p>
              </div>
           </div>

           <div className="grid grid-cols-3 gap-6">
              <div className="space-y-1">
                <p className="text-[9px] font-black text-gray-600 uppercase tracking-widest">Followers</p>
                <p className="text-xl font-black text-white">{creator.stats.tiktok.followers}</p>
              </div>
              <div className="space-y-1">
                <p className="text-[9px] font-black text-gray-600 uppercase tracking-widest">Engagement</p>
                <p className="text-xl font-black text-teal-400">{creator.stats.tiktok.engagement}</p>
              </div>
              <div className="space-y-1 text-right">
                <p className="text-[9px] font-black text-gray-600 uppercase tracking-widest">Avg. Views</p>
                <p className="text-xl font-black text-white">{creator.stats.tiktok.avgViews}</p>
              </div>
           </div>

           <div className="pt-6 border-t border-white/5">
              <p className="text-[9px] text-gray-700 font-bold uppercase tracking-[0.4em] mb-4">LATEST PERFORMANCE GRAPH</p>
              <div className="flex items-end gap-1 h-20">
                 {[40, 60, 45, 90, 75, 85, 100, 70, 95, 80].map((h, i) => (
                   <div key={i} className="flex-1 bg-white/5 rounded-t-md relative group/bar overflow-hidden">
                      <div 
                        className="absolute bottom-0 w-full bg-teal-500/40 transition-all duration-1000 group-hover/bar:bg-teal-500" 
                        style={{ height: `${h}%` }}
                      />
                   </div>
                 ))}
              </div>
           </div>
        </div>

        {/* Instagram Metrics */}
        <div className="bg-[#11141A] border border-white/5 rounded-[48px] p-8 md:p-10 space-y-10 relative overflow-hidden group">
           <div className="absolute top-[-20%] right-[-10%] w-48 h-48 bg-purple-500/5 rounded-full blur-3xl group-hover:bg-purple-500/10 transition-all"></div>
           <div className="flex items-center gap-4">
              <div className="w-14 h-14 bg-gradient-to-tr from-[#f9ce34] via-[#ee2a7b] to-[#6228d7] rounded-2xl flex items-center justify-center text-white border border-white/10 shadow-2xl">
                <IconInstagram />
              </div>
              <div>
                <h3 className="text-2xl font-black text-white tracking-tight uppercase font-display leading-none">Instagram Core</h3>
                <p className="text-[10px] font-black text-purple-400 uppercase tracking-widest mt-1">High-Fidelity reach</p>
              </div>
           </div>

           <div className="grid grid-cols-3 gap-6">
              <div className="space-y-1">
                <p className="text-[9px] font-black text-gray-600 uppercase tracking-widest">Followers</p>
                <p className="text-xl font-black text-white">{creator.stats.instagram.followers}</p>
              </div>
              <div className="space-y-1">
                <p className="text-[9px] font-black text-gray-500 uppercase tracking-widest pl-1 leading-none mt-1">Followers</p>
                <p className="text-xl font-black text-white">{creator.stats.instagram.followers}</p>
              </div>
              <div className="space-y-1">
                <p className="text-[9px] font-black text-gray-600 uppercase tracking-widest">Engagement</p>
                <p className="text-xl font-black text-purple-400">{creator.stats.instagram.engagement}</p>
              </div>
              <div className="space-y-1 text-right">
                <p className="text-[9px] font-black text-gray-600 uppercase tracking-widest">Avg. Views</p>
                <p className="text-xl font-black text-white">{creator.stats.instagram.avgViews}</p>
              </div>
           </div>

           <div className="pt-6 border-t border-white/5">
              <p className="text-[9px] text-gray-700 font-bold uppercase tracking-[0.4em] mb-4">REEL VELOCITY INDEX</p>
              <div className="flex items-end gap-1 h-20">
                 {[30, 45, 80, 55, 65, 40, 50, 60, 35, 70].map((h, i) => (
                   <div key={i} className="flex-1 bg-white/5 rounded-t-md relative group/bar overflow-hidden">
                      <div 
                        className="absolute bottom-0 w-full bg-purple-500/40 transition-all duration-1000 group-hover/bar:bg-purple-500" 
                        style={{ height: `${h}%` }}
                      />
                   </div>
                 ))}
              </div>
           </div>
        </div>
      </section>

      {/* Creative Portfolio Gallery */}
      <section className="space-y-8">
        <div className="flex items-end justify-between px-2">
          <div className="space-y-1">
            <h2 className="text-3xl font-black text-white tracking-tighter uppercase font-display">Portfolio Matrix</h2>
            <p className="text-[10px] font-black text-gray-500 uppercase tracking-widest">Selected Masterpieces & High Performance Ads</p>
          </div>
          <button className="text-teal-500 text-[10px] font-black uppercase tracking-widest hover:text-white transition-all">Filter by Type ↓</button>
        </div>

        <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          {creator.contentGallery.map((img, i) => (
            <div 
              key={i} 
              onClick={() => setSelectedGalleryImage(img)}
              className="group aspect-[3/4] bg-[#11141A] border border-white/5 rounded-[32px] overflow-hidden relative shadow-2xl cursor-pointer"
            >
               <img 
                  src={img} 
                  onError={handleImageError}
                  loading="lazy"
                  decoding="async"
                  className="w-full h-full object-cover grayscale-[0.2] group-hover:grayscale-0 group-hover:scale-105 transition-all duration-1000" 
                  alt={`Portfolio Item ${i + 1}`} 
                />
               <div className="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500">
                  <div className="absolute bottom-6 left-6 right-6 flex items-center justify-between">
                     <span className="text-[10px] font-black text-teal-400 uppercase tracking-widest">AD_UNIT_0{i+1}</span>
                     <div className="w-8 h-8 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center text-white text-xs">▶</div>
                  </div>
               </div>
            </div>
          ))}
          
          <div className="aspect-[3/4] bg-white/[0.02] border border-dashed border-white/5 rounded-[32px] flex flex-col items-center justify-center text-center p-8 space-y-4 opacity-40">
             <div className="text-2xl text-gray-600">+</div>
             <p className="text-[9px] font-black text-gray-700 uppercase tracking-widest">Loading Master Asset...</p>
          </div>
        </div>
      </section>

      {/* Sticky Bottom Actions for Mobile */}
      <div className="md:hidden fixed bottom-24 left-1/2 -translate-x-1/2 w-[90%] z-50 flex flex-col gap-3">
        <button 
          onClick={() => setIsContactModalOpen(true)}
          className="w-full bg-white/10 backdrop-blur-xl text-white font-black py-4 rounded-3xl text-sm uppercase tracking-widest border border-white/10 shadow-2xl active:scale-95 transition-all"
        >
          Contact Creator
        </button>
        <button className="w-full bg-teal-500 text-black font-black py-5 rounded-3xl text-sm uppercase tracking-widest shadow-2xl shadow-teal-500/40 active:scale-95 transition-all">
          Invite to Campaign Node
        </button>
      </div>
    </div>
  );
};

export default CreatorDetail;
