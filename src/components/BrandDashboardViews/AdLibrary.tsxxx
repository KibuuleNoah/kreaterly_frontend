
import React, { useState } from 'react';
import { IconAdLibrary, IconX } from '../components/Icons';
import { GoogleGenAI } from "@google/genai";

const MOCK_ASSETS = [
  { id: 1, title: '5G Speed Test - Downtown', performance: 'Excellent', views: '2.4M', creator: 'Nasser Ndugwa', thumbnail: 'https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=800&auto=format&fit=crop&q=80' },
  { id: 2, title: 'Studio Performance Clip', performance: 'Good', views: '840K', creator: 'Nayebare Winnie', thumbnail: 'https://images.unsplash.com/photo-1501386761578-eac5c94b800a?w=800&auto=format&fit=crop&q=80' },
  { id: 3, title: 'Zinger Burger Reveal', performance: 'Viral', views: '4.2M', creator: 'Sean Offixial', thumbnail: 'https://images.unsplash.com/photo-1513104890138-7c749659a591?w=800&auto=format&fit=crop&q=80' },
];

const AdLibrary: React.FC = () => {
  const [editingAsset, setEditingAsset] = useState<typeof MOCK_ASSETS[0] | null>(null);
  const [prompt, setPrompt] = useState('');
  const [isProcessing, setIsProcessing] = useState(false);
  const [editedImage, setEditedImage] = useState<string | null>(null);
  const [statusMessage, setStatusMessage] = useState('');

  const toBase64 = (url: string): Promise<string> => {
    return new Promise((resolve, reject) => {
      const img = new Image();
      img.crossOrigin = 'Anonymous';
      img.onload = () => {
        const canvas = document.createElement('canvas');
        canvas.width = img.width;
        canvas.height = img.height;
        const ctx = canvas.getContext('2d');
        ctx?.drawImage(img, 0, 0);
        const dataURL = canvas.toDataURL('image/png');
        resolve(dataURL.split(',')[1]);
      };
      img.onerror = reject;
      img.src = url;
    });
  };

  const handleAiEdit = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!editingAsset || !prompt.trim()) return;

    setIsProcessing(true);
    setEditedImage(null);
    setStatusMessage('Synchronizing with Gemini Creative Engine...');

    try {
      const base64Data = await toBase64(editingAsset.thumbnail);
      const ai = new GoogleGenAI({ apiKey: process.env.API_KEY });
      
      setStatusMessage('Analyzing pixel architecture...');
      
      const response = await ai.models.generateContent({
        model: 'gemini-2.5-flash-image',
        contents: {
          parts: [
            {
              inlineData: {
                data: base64Data,
                mimeType: 'image/png',
              },
            },
            {
              text: `Apply the following change to this image: ${prompt}. Return the resulting edited image.`,
            },
          ],
        },
      });

      setStatusMessage('Rendering high-fidelity output...');

      for (const part of response.candidates[0].content.parts) {
        if (part.inlineData) {
          setEditedImage(`data:image/png;base64,${part.inlineData.data}`);
          break;
        }
      }
    } catch (err) {
      console.error(err);
      setStatusMessage('Neural Link Failure. Please check your prompt and try again.');
    } finally {
      setIsProcessing(false);
    }
  };

  return (
    <div className="space-y-8 md:space-y-10 animate-in fade-in duration-700 pb-12">
      <header className="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div className="space-y-2">
          <p className="text-teal-500 text-[9px] md:text-[10px] font-black uppercase tracking-[0.4em]">Asset Management</p>
          <h1 className="text-4xl md:text-6xl font-black text-white tracking-tighter uppercase font-display leading-none">Ad Library</h1>
          <p className="text-gray-500 text-sm md:text-lg font-medium max-w-xl">Whitelist and repurpose your best organic campaign clips for paid media amplification.</p>
        </div>
        <button className="w-full md:w-auto bg-teal-500 text-black font-black px-10 py-5 rounded-2xl text-[10px] uppercase tracking-widest shadow-xl shadow-teal-500/20 hover:scale-105 active:scale-95 transition-all">
          Upload Master Asset
        </button>
      </header>

      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 md:gap-6">
        {MOCK_ASSETS.map(asset => (
          <div key={asset.id} className="bg-[#11141A] border border-white/5 rounded-3xl md:rounded-[40px] overflow-hidden group hover:border-teal-500/30 transition-all flex flex-col">
            <div className="aspect-[9/16] relative bg-black/40 overflow-hidden">
              <img src={asset.thumbnail} className="w-full h-full object-cover grayscale-[0.3] group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" alt="" />
              <div className="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-80" />
              <div className="absolute top-4 md:top-6 right-4 md:right-6">
                <span className="bg-white/10 backdrop-blur-md px-3 py-1.5 rounded-xl text-[7px] md:text-[8px] font-black uppercase text-white border border-white/10 tracking-widest">
                  {asset.performance}
                </span>
              </div>
              
              {/* AI Edit Button Overlay */}
              <div className="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                <button 
                  onClick={() => {
                    setEditingAsset(asset);
                    setEditedImage(null);
                    setPrompt('');
                  }}
                  className="bg-purple-600 text-white font-black px-6 py-3 rounded-xl text-[10px] uppercase tracking-widest shadow-2xl hover:scale-105 transition-transform flex items-center gap-2"
                >
                  <span>✨ AI Magic Edit</span>
                </button>
              </div>

              <div className="absolute bottom-4 md:bottom-6 left-4 md:left-6 right-4 md:right-6">
                <p className="text-[9px] font-black text-teal-500 uppercase tracking-widest mb-1 truncate">{asset.creator}</p>
                <h4 className="text-base md:text-lg font-black text-white tracking-tight leading-tight line-clamp-2">{asset.title}</h4>
                <p className="text-[9px] font-black text-white/40 mt-2 uppercase tracking-widest">{asset.views} Reach</p>
              </div>
            </div>
            <div className="p-4 md:p-6 border-t border-white/5 grid grid-cols-2 gap-2">
              <button className="py-3 bg-white/5 border border-white/5 rounded-xl text-[8px] md:text-[9px] font-black text-gray-500 uppercase tracking-widest hover:text-white transition-all">Download</button>
              <button className="py-3 bg-teal-500/10 border border-teal-500/20 rounded-xl text-[8px] md:text-[9px] font-black text-teal-400 uppercase tracking-widest hover:bg-teal-500 hover:text-black transition-all">Push to Ads</button>
            </div>
          </div>
        ))}

        <div className="aspect-[9/16] bg-white/[0.02] border border-dashed border-white/10 rounded-3xl md:rounded-[40px] flex flex-col items-center justify-center text-center p-8 space-y-4 hover:border-white/20 transition-all group cursor-pointer">
           <div className="w-14 h-14 md:w-16 md:h-16 bg-white/5 rounded-2xl flex items-center justify-center text-gray-600 group-hover:text-white transition-all shadow-xl">
             <span className="text-2xl md:text-3xl">+</span>
           </div>
           <div className="min-w-0">
             <p className="text-xs md:text-sm font-black text-white uppercase tracking-tight">Add Collection</p>
             <p className="text-[9px] text-gray-600 mt-1 uppercase tracking-widest truncate">Organize your creative assets</p>
           </div>
        </div>
      </div>

      {/* AI EDIT MODAL */}
      {editingAsset && (
        <div className="fixed inset-0 z-[600] flex items-center justify-center p-4 md:p-10">
          <div className="absolute inset-0 bg-[#0A0B0E]/95 backdrop-blur-2xl" onClick={() => !isProcessing && setEditingAsset(null)} />
          
          <div className="bg-[#11141A] border border-white/10 w-full max-w-5xl rounded-[48px] overflow-hidden relative z-10 shadow-[0_50px_100px_rgba(0,0,0,0.8)] flex flex-col md:flex-row h-full max-h-[800px] animate-in zoom-in-95 duration-500">
            {/* Left: Preview */}
            <div className="flex-1 bg-black/40 relative flex items-center justify-center p-6 border-b md:border-b-0 md:border-r border-white/5">
              <div className="relative h-full w-full flex items-center justify-center">
                {isProcessing ? (
                  <div className="text-center space-y-6">
                    <div className="w-24 h-24 border-4 border-teal-500/20 border-t-teal-500 rounded-full animate-spin mx-auto shadow-[0_0_30px_rgba(20,184,166,0.3)]"></div>
                    <p className="text-teal-400 text-xs font-black uppercase tracking-[0.4em] animate-pulse">{statusMessage}</p>
                  </div>
                ) : (
                  <img 
                    src={editedImage || editingAsset.thumbnail} 
                    className="max-h-full max-w-full object-contain rounded-2xl shadow-3xl animate-in fade-in duration-700" 
                    alt="Asset Preview" 
                  />
                )}
                {editedImage && (
                   <div className="absolute top-4 right-4 bg-teal-500 text-black px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-2xl">
                     AI Generated
                   </div>
                )}
              </div>
            </div>

            {/* Right: Controls */}
            <div className="w-full md:w-[380px] p-8 md:p-12 flex flex-col gap-10 bg-[#11141A]">
              <div className="flex justify-between items-start">
                <div className="space-y-1">
                  <p className="text-purple-500 text-[10px] font-black uppercase tracking-[0.4em]">AI Creator Studio</p>
                  <h3 className="text-3xl font-black text-white uppercase font-display leading-none">Image Lab</h3>
                </div>
                <button 
                  disabled={isProcessing}
                  onClick={() => setEditingAsset(null)} 
                  className="text-gray-500 hover:text-white transition-colors"
                >
                  <IconX />
                </button>
              </div>

              <div className="space-y-4">
                <div className="flex justify-between px-1">
                  <label className="text-[10px] font-black text-gray-500 uppercase tracking-widest">Modification Prompt</label>
                  <span className="text-[10px] font-black text-teal-500 uppercase tracking-widest">Nano Banana v2.5</span>
                </div>
                <textarea 
                  disabled={isProcessing}
                  value={prompt}
                  onChange={e => setPrompt(e.target.value)}
                  placeholder="E.g. 'Add a retro 90s VHS filter' or 'Make the lighting more dramatic with purple glows'"
                  className="w-full bg-black/40 border border-white/5 rounded-3xl p-6 text-sm text-white font-medium focus:border-teal-500/50 outline-none transition-all resize-none h-40 placeholder:text-gray-800 shadow-inner"
                />
                <div className="grid grid-cols-2 gap-2">
                  {['Retro Filter', 'Cinematic Lighting', 'Remove Background', 'Sharpen Pixels'].map(tag => (
                    <button 
                      key={tag}
                      onClick={() => setPrompt(prev => prev ? `${prev}, ${tag}` : tag)}
                      className="text-[8px] font-black uppercase tracking-widest bg-white/5 border border-white/5 py-2 rounded-lg text-gray-500 hover:text-white hover:border-teal-500/30 transition-all"
                    >
                      + {tag}
                    </button>
                  ))}
                </div>
              </div>

              <div className="mt-auto space-y-4">
                {editedImage ? (
                  <>
                    <button 
                      onClick={() => setEditedImage(null)}
                      className="w-full bg-white/5 border border-white/10 text-white font-black py-4 rounded-2xl text-[10px] uppercase tracking-[0.2em] transition-all"
                    >
                      Discard & Re-edit
                    </button>
                    <button 
                      className="w-full bg-teal-500 text-black font-black py-5 rounded-2xl text-[11px] uppercase tracking-[0.2em] shadow-xl shadow-teal-500/20 active:scale-95 transition-all"
                    >
                      Save to Library
                    </button>
                  </>
                ) : (
                  <button 
                    onClick={handleAiEdit}
                    disabled={isProcessing || !prompt.trim()}
                    className="w-full bg-gradient-to-r from-purple-600 to-teal-500 text-white font-black py-6 rounded-3xl text-[12px] uppercase tracking-[0.2em] shadow-2xl shadow-purple-500/20 hover:brightness-110 active:scale-95 transition-all disabled:opacity-20"
                  >
                    {isProcessing ? 'Generating...' : 'Run Neural Process'}
                  </button>
                )}
                <p className="text-center text-[8px] text-gray-700 font-black uppercase tracking-[0.4em]">
                  Encrypted AI Node Protocol 2.5
                </p>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
};

export default AdLibrary;
